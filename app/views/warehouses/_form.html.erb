<%= form_with(model: warehouse, local: true, class: "needs-validation") do |form| %>
  <% if warehouse.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(warehouse.errors.count, "error") %> prohibited this warehouse from being saved:</h4>
      <ul>
        <% warehouse.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", warehouses_path, class: "btn btn-secondary" %>
  </div>
<% end %>