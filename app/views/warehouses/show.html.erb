<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @warehouse.name %></h1>
    <div>
      <%= link_to "Back", warehouses_path, class: "btn btn-secondary" %>
      <% if current_user.admin? %>
        <%= link_to "Edit", edit_warehouse_path(@warehouse), class: "btn btn-warning" %>
      <% end %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-4">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Locations</h5>
          <% if current_user.admin? || current_user.manager? %>
            <%= link_to "Manage", warehouse_locations_path(@warehouse), class: "btn btn-sm btn-primary" %>
          <% end %>
        </div>
        <div class="card-body">
          <p><strong>Total:</strong> <%= @locations.count %></p>
          <p><strong>Occupied:</strong> <%= @locations.select(&:occupied?).count %></p>
          <p><strong>Available:</strong> <%= @locations.reject(&:occupied?).count %></p>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Stock Items</h5>
          <% if current_user.admin? || current_user.manager? %>
            <%= link_to "Manage", warehouse_stock_items_path(@warehouse), class: "btn btn-sm btn-primary" %>
          <% end %>
        </div>
        <div class="card-body">
          <p><strong>Total Items:</strong> <%= @stock_items.count %></p>
          <p><strong>Total Quantity:</strong> <%= @stock_items.sum(:quantity) %></p>
          <p><strong>Items with Location:</strong> <%= @stock_items.where.not(location_id: nil).count %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">Recent Stock Items</h5>
    </div>
    <div class="card-body">
      <% if @stock_items.any? %>
        <table class="table table-sm">
          <thead>
            <tr>
              <th>Name</th>
              <th>Quantity</th>
              <th>Location</th>
              <th>Expiry Date</th>
            </tr>
          </thead>
          <tbody>
            <% @stock_items.limit(10).each do |item| %>
              <tr class="<%= 'table-danger' if item.expired? %>">
                <td><%= link_to item.name, warehouse_stock_item_path(@warehouse, item) %></td>
                <td><%= item.quantity %></td>
                <td>
                  <% if item.location %>
                    <%= item.location.code %>
                  <% else %>
                    <span class="text-muted">Unassigned</span>
                  <% end %>
                </td>
                <td>
                  <% if item.expired_date %>
                    <%= item.expired_date.strftime("%Y-%m-%d") %>
                    <% if item.expired? %>
                      <span class="badge bg-danger">Expired</span>
                    <% end %>
                  <% else %>
                    <span class="text-muted">No expiry</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No stock items.</p>
      <% end %>
    </div>
  </div>
</div>
