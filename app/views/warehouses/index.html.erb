<!-- app/views/warehouses/index.html.erb -->
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Warehouses</h1>
    <% if current_user.admin? %>
      <%= link_to "New Warehouse", new_warehouse_path, class: "btn btn-primary" %>
    <% end %>
  </div>

  <div class="card">
    <div class="card-body">
      <% if @warehouses.any? %>
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Name</th>
              <th>Locations</th>
              <th>Stock Items</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @warehouses.each do |warehouse| %>
              <tr>
                <td><%= link_to warehouse.name, warehouse_path(warehouse) %></td>
                <td><%= warehouse.locations.count %></td>
                <td><%= warehouse.stock_items.count %></td>
                <td>
                  <%= link_to "View", warehouse_path(warehouse), class: "btn btn-sm btn-info" %>
                  <% if current_user.admin? %>
                    <%= link_to "Edit", edit_warehouse_path(warehouse), class: "btn btn-sm btn-warning" %>
                    <%= button_to "Delete", warehouse_path(warehouse), method: :delete, 
                        data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No warehouses found.</p>
      <% end %>
    </div>
  </div>
</div>
