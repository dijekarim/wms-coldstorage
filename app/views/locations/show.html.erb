<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Location: <%= @location.code %></h1>
    <div class="flex space-x-2">
      <% if policy(@location).update? %>
        <%= link_to 'Edit', edit_warehouse_location_path(@warehouse, @location), 
                    class: "bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded" %>
      <% end %>
      <% if policy(@location).destroy? %>
        <%= link_to 'Delete', warehouse_location_path(@warehouse, @location), 
                    method: :delete,
                    data: { confirm: 'Are you sure?' },
                    class: "bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded" %>
      <% end %>
    </div>
  </div>

  <div class="mb-4">
    <%= link_to "← Back to Locations", warehouse_locations_path(@warehouse), 
                class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Location Details</h3>
    </div>
    <div class="border-t border-gray-200">
      <dl>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Code</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= @location.code %>
          </dd>
        </div>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                         <%= @location.occupied? ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' %>">
              <%= @location.occupied? ? 'Occupied' : 'Free' %>
            </span>
          </dd>
        </div>
        <% if @location.stock_item %>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Stock Item</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= link_to @location.stock_item.name, 
                          warehouse_stock_item_path(@warehouse, @location.stock_item),
                          class: "text-blue-600 hover:text-blue-800" %>
            </dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Quantity</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= @location.stock_item.quantity %>
            </dd>
          </div>
          <% if @location.stock_item.expired_date %>
            <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500">Expiry Date</dt>
              <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                <%= @location.stock_item.expired_date.strftime("%B %d, %Y") %>
                <% if @location.stock_item.expired? %>
                  <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    Expired
                  </span>
                <% end %>
              </dd>
            </div>
          <% end %>
        <% end %>
      </dl>
    </div>
  </div>
</div>
