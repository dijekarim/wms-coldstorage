<!-- app/views/stock_items/index.html.erb -->
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Stock Items - <%= @warehouse.name %></h1>
    <div>
      <%= link_to "Back to Warehouse", warehouse_path(@warehouse), class: "btn btn-secondary" %>
      <% if current_user.admin? || current_user.manager? %>
        <%= link_to "New Stock Item", new_warehouse_stock_item_path(@warehouse), class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>

  <div class="card mb-3">
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <h6>Filter:</h6>
          <%= link_to "All Items", warehouse_stock_items_path(@warehouse), 
              class: "btn btn-sm #{'btn-primary' unless params[:filter]} #{'btn-outline-primary' if params[:filter]}" %>
          <%= link_to "Not Expired", warehouse_stock_items_path(@warehouse, filter: 'not_expired'), 
              class: "btn btn-sm #{'btn-primary' if params[:filter] == 'not_expired'} #{'btn-outline-primary' unless params[:filter] == 'not_expired'}" %>
        </div>
        <div class="col-md-6">
          <h6>Sort:</h6>
          <%= link_to "By Name", warehouse_stock_items_path(@warehouse), 
              class: "btn btn-sm #{'btn-info' unless params[:sort]} #{'btn-outline-info' if params[:sort]}" %>
          <%= link_to "By Expiry", warehouse_stock_items_path(@warehouse, sort: 'expiry'), 
              class: "btn btn-sm #{'btn-info' if params[:sort] == 'expiry'} #{'btn-outline-info' unless params[:sort] == 'expiry'}" %>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <% if @stock_items.any? %>
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Name</th>
              <th>Quantity</th>
              <th>Location</th>
              <th>Expiry Date</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @stock_items.each do |item| %>
              <tr class="<%= 'table-danger' if item.expired? %>">
                <td><%= link_to item.name, warehouse_stock_item_path(@warehouse, item) %></td>
                <td><%= item.quantity %></td>
                <td>
                  <% if item.location %>
                    <%= item.location.code %>
                  <% else %>
                    <span class="text-muted">Unassigned</span>
                  <% end %>
                </td>
                <td>
                  <% if item.expired_date %>
                    <%= item.expired_date.strftime("%Y-%m-%d") %>
                  <% else %>
                    <span class="text-muted">No expiry</span>
                  <% end %>
                </td>
                <td>
                  <% if item.expired? %>
                    <span class="badge bg-danger">Expired</span>
                  <% elsif item.expired_date && item.expired_date < Date.current + 30.days %>
                    <span class="badge bg-warning">Expiring Soon</span>
                  <% else %>
                    <span class="badge bg-success">Active</span>
                  <% end %>
                </td>
                <td>
                  <%= link_to "View", warehouse_stock_item_path(@warehouse, item), 
                      class: "btn btn-sm btn-info" %>
                  <% if current_user.admin? || current_user.manager? %>
                    <%= link_to "Edit", edit_warehouse_stock_item_path(@warehouse, item), 
                        class: "btn btn-sm btn-warning" %>
                    <%= button_to "Delete", warehouse_stock_item_path(@warehouse, item), 
                        method: :delete, data: { confirm: "Are you sure?" }, 
                        class: "btn btn-sm btn-danger" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">No stock items found.</p>
      <% end %>
    </div>
  </div>
</div>
