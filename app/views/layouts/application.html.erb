<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "WMS Coldstorage" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-64 bg-white shadow-md h-screen flex flex-col">
      <div class="p-4 font-bold text-xl border-b">📦 WMS</div>
      
      <nav class="mt-4 flex-1 space-y-2">
        <% if user_signed_in? %>
          <% if current_user.admin? %>
            <%= link_to "Dashboard", admin_dashboard_path,
              class: "block px-4 py-2 rounded hover:bg-gray-200 #{current_page?(admin_dashboard_path) ? 'bg-gray-200 font-semibold' : ''}" %>
            <%= link_to "Users", users_path,
              class: "block px-4 py-2 rounded hover:bg-gray-200 #{current_page?(users_path) ? 'bg-gray-200 font-semibold' : ''}" %>
            <%= link_to "Warehouses", warehouses_path,
              class: "block px-4 py-2 rounded hover:bg-gray-200 #{current_page?(warehouses_path) ? 'bg-gray-200 font-semibold' : ''}" %>
          <% elsif current_user.manager? %>
            <%= link_to "Dashboard", manager_dashboard_path,
              class: "block px-4 py-2 rounded hover:bg-gray-200 #{current_page?(manager_dashboard_path) ? 'bg-gray-200 font-semibold' : ''}" %>
            <%= link_to "Receiving", new_warehouse_stock_item_path(current_user),
              class: "block px-4 py-2 rounded hover:bg-gray-200" %>
            <%= link_to "Products", warehouse_stock_items_path(current_user),
              class: "block px-4 py-2 rounded hover:bg-gray-200" %>
          <% elsif current_user.viewer? %>
            <%= link_to "Dashboard", viewer_dashboard_path,
              class: "block px-4 py-2 rounded hover:bg-gray-200 #{current_page?(viewer_dashboard_path) ? 'bg-gray-200 font-semibold' : ''}" %>
            <%= link_to "Stock", warehouse_stock_items_path(current_user),
              class: "block px-4 py-2 rounded hover:bg-gray-200" %>
          <% end %>
        <% end %>
      </nav>

      <!-- Logout at bottom -->
      <% if user_signed_in? %>
        <div class="p-4 border-t">
          <%= button_to "Logout", destroy_user_session_path, method: :delete,
            class: "block px-4 py-2 text-red-600 hover:bg-gray-200 rounded" %>
        </div>
      <% end %>
    </aside>

    <!-- Main content area -->
    <div class="flex-1 flex flex-col">
      <!-- Topbar -->
      <header class="bg-white shadow px-6 py-4 flex justify-between items-center">
        <h1 class="text-xl font-bold">Dashboard</h1>
        <% if user_signed_in? %>
          <span class="text-gray-600">👤 <%= current_user.email %> (<%= current_user.role %>)</span>
        <% end %>
      </header>

      <!-- Flash messages -->
      <main class="flex-1 p-6">
        <% flash.each do |key, value| %>
          <div class="mb-4 p-4 rounded
                      <%= key == 'notice' ? 'bg-green-100 text-green-800' : '' %>
                      <%= key == 'alert' ? 'bg-red-100 text-red-800' : '' %>">
            <%= value %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>